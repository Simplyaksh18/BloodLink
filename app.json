{
  "expo": {
    "name": "BloodLinkApp",
    "slug": "BloodLinkApp",
    "version": "1.0.0",
    "scheme": "bloodlink",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "owner": "simply.aksh",
    "sdkVersion": "54.0.0",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.simplyaksh.bloodlink",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BloodLink uses your location to show nearby blood requests, compatible donors and blood banks.",
        "NSPhotoLibraryUsageDescription": "BloodLink accesses your photo library so you can upload profile images, identity documents and donation proof.",
        "NSCameraUsageDescription": "BloodLink uses the camera so you can capture verification documents and donation proof.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.simply.aksh.BloodLinkApp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#E53935",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BloodLink to access your camera to scan codes."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": ["RNFBApp", "RNFBAuth"]
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ddf338ea-77f2-4099-b090-714852109b68"
      }
    }
  }
}
